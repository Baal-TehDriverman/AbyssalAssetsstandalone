{
  "name": "abyssal-assets-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:coverage": "vitest run --coverage",
    "cap:init": "cap init",
    "cap:add": "cap add android",
    "cap:sync": "cap sync android",
    "cap:open": "cap open android",
    "cap:build": "npm run build && cap sync android",
    "cap:run": "npm run build && cap run android",
    "pwa:build": "npm run build && npx workbox generateSW workbox-config.js"
  },
  "dependencies": {
    "phaser": "^3.80.0",
    "socket.io-client": "^4.7.0",
    "zustand": "^4.4.0",
    "@tanstack/react-query": "^5.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/local-notifications": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@capacitor/background-runner": "^6.0.0",
    "@capacitor/network": "^6.0.0",
    "@capacitor/device": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/share": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "vitest": "^2.0.0",
    "@vitest/ui": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "playwright": "^1.45.0",
    "@playwright/test": "^1.45.0",
    "jsdom": "^24.0.0",
    "happy-dom": "^14.0.0",
    "@capacitor/cli": "^6.0.0",
    "workbox-cli": "^7.0.0"
  }
}